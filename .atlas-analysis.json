  "keyFeatures": [
    "28+ diagram types including flowcharts, sequence diagrams, class diagrams, and more",
    "Markdown-inspired text syntax for creating diagrams",
    "Browser and Node.js rendering support",
    "Extensive theming and styling options",
    "Accessibility support with ARIA labels",
    "Custom icon packs and layout engines",
    "Plugin system for external diagrams",
    "Live editor and CDN distribution"
